CREATE VIEW IF NOT EXISTS referansesjekk_utdrag AS
SELECT
  akpk.pensumliste_id AS pensumid,
  ar.unik_bok_id      AS unik_bok_id,
  ar.id               AS id,
  ar.unik_utdrag_id   AS unik_utdrag_id,
  ar.chapter          AS chapter,
  ar.chapter_title    AS chapter_title,
  ar.chapter_author   AS chapter_author,
  ar.public_note      AS public_note,
  akpk.code           AS code,
  CONCAT_WS(
    ', ',
    CASE WHEN ar.start_page  IS NOT NULL AND ar.end_page  IS NOT NULL THEN CONCAT(ar.start_page,  '-', ar.end_page)  END,
    CASE WHEN ar.start_page2 IS NOT NULL AND ar.end_page2 IS NOT NULL THEN CONCAT(ar.start_page2, '-', ar.end_page2) END,
    CASE WHEN ar.start_page3 IS NOT NULL AND ar.end_page3 IS NOT NULL THEN CONCAT(ar.start_page3, '-', ar.end_page3) END,
    CASE WHEN ar.start_page4 IS NOT NULL AND ar.end_page4 IS NOT NULL THEN CONCAT(ar.start_page4, '-', ar.end_page4) END,
    CASE WHEN ar.start_page5 IS NOT NULL AND ar.end_page5 IS NOT NULL THEN CONCAT(ar.start_page5, '-', ar.end_page5) END,
    CASE WHEN ar.start_page6 IS NOT NULL AND ar.end_page6 IS NOT NULL THEN CONCAT(ar.start_page6, '-', ar.end_page6) END,
    CASE WHEN ar.start_page7 IS NOT NULL AND ar.end_page7 IS NOT NULL THEN CONCAT(ar.start_page7, '-', ar.end_page7) END,
    CASE WHEN ar.start_page8 IS NOT NULL AND ar.end_page8 IS NOT NULL THEN CONCAT(ar.start_page8, '-', ar.end_page8) END,
    CASE WHEN ar.start_page9 IS NOT NULL AND ar.end_page9 IS NOT NULL THEN CONCAT(ar.start_page9, '-', ar.end_page9) END,
    CASE WHEN ar.start_page10 IS NOT NULL AND ar.end_page10 IS NOT NULL THEN CONCAT(ar.start_page10, '-', ar.end_page10) END
  ) AS formatted_pages
FROM api_alma_kurs_pensumlister_kobling AS akpk
JOIN api_alma_referanser AS ar
  ON ar.pensumliste_id = akpk.pensumliste_id
WHERE ar.secondary_type IN ('Book', 'Book Extract', 'Book Chapter', 'Score')
  AND akpk.status_pensumliste2 IN ('ReadyForProcessing','BeingProcessed','Complete')
  AND ar.citation_tags IN ('1','3','4','12')
GROUP BY akpk.pensumliste_id, ar.id;

CREATE VIEW arbeidsoversikt_art IF NOT EXISTS AS
SELECT
  api_alma_referanser.id                         AS SiteringsID,
  api_alma_referanser.pensumliste_id             AS `PensumlisteID ( List ID)`,
  api_alma_pensumlister.name                     AS `Emnekode og emnenavn`,
  api_alma_referanser.secondary_type             AS Materialtype,
  api_alma_referanser.article_title              AS Artikkeltittel,
  api_alma_referanser.author                     AS Forfatter,
  api_alma_referanser.publication_date           AS Publiseringsdato,
  api_alma_referanser.journal_title              AS Tidsskrift,
  api_alma_referanser.publisher                  AS Utgiver,
  api_alma_referanser.issn                       AS ISSN,
  api_alma_referanser.volume                     AS Volume,
  api_alma_referanser.issue                      AS Nummer,
  api_alma_referanser.sammensatt_sideangivelse   AS Sideangivelse,
  api_alma_referanser.public_note                AS Siteringsnote,
  '2000'                                         AS Behandlingskode,
  api_alma_referanser.kommentar                  AS Kommentar,
  ''                                             AS `Sendt epost`,
  api_alma_referanser.last_modified_date         AS `Last modificated`,
  api_alma_kurs.fakultet                         AS Fakultet,
  api_alma_kurs_pensumlister_kobling.aarsem      AS `ÅrSemester`,
  DATE_FORMAT(CURDATE(), '%d.%m.%Y')             AS `Første gang importert`
FROM api_alma_kurs_pensumlister_kobling
JOIN api_alma_kurs
  ON api_alma_kurs_pensumlister_kobling.kurs_id = api_alma_kurs.id
JOIN api_alma_pensumlister
  ON api_alma_kurs_pensumlister_kobling.pensumliste_id = api_alma_pensumlister.id
JOIN api_alma_referanser
  ON api_alma_kurs_pensumlister_kobling.pensumliste_id = api_alma_referanser.pensumliste_id
JOIN KursPensumlisteView
  ON api_alma_kurs_pensumlister_kobling.kurs_id = KursPensumlisteView.kurs_id
WHERE
  (
    (
      api_alma_referanser.citation_tags = 1
      AND api_alma_referanser.indikator_vaar_fil = 0
    )
    OR api_alma_referanser.citation_tags IN ('3', '4', '12')
  )
  AND api_alma_referanser.map_secondary_type = '2'
GROUP BY
  api_alma_referanser.id,
  api_alma_kurs_pensumlister_kobling.aarsem
UNION ALL
SELECT
  NULL AS SiteringsID,
  NULL AS `PensumlisteID ( List ID)`,
  NULL AS `Emnekode og emnenavn`,
  NULL AS Materialtype,
  NULL AS Artikkeltittel,
  NULL AS Forfatter,
  NULL AS Publiseringsdato,
  NULL AS Tidsskrift,
  NULL AS Utgiver,
  NULL AS ISSN,
  NULL AS Volume,
  NULL AS Nummer,
  NULL AS Sideangivelse,
  NULL AS Siteringsnote,
  '2000' AS Behandlingskode,
  NULL AS Kommentar,
  ''   AS `Sendt epost`,
  NULL AS `Last modificated`,
  NULL AS Fakultet,
  NULL AS `ÅrSemester`,
  DATE_FORMAT(CURDATE(), '%d.%m.%Y') AS `Første gang importert`;
